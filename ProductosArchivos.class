import java.io.File;
import java.io.FileNotFoundException;
import java.util.Scanner;

public class ProductosArchivo {
   public ProductosArchivo() {
   }

   public static void main(String[] var0) {
      File var1 = new File("productos.txt");
      double var2 = (double)0.0F;
      String var4 = "";
      double var5 = (double)-1.0F;

      try {
         Scanner var7 = new Scanner(var1);
         System.out.println("--- REPORTE DE INVENTARIO ---");

         String var8;
         double var12;
         for(; var7.hasNext(); System.out.println("Articulo: " + var8 + " | Subtotal: $" + var12)) {
            var8 = var7.next();
            double var9 = var7.nextDouble();
            int var11 = var7.nextInt();
            var12 = var9 * (double)var11;
            var2 += var12;
            if (var9 > var5) {
               var5 = var9;
               var4 = var8;
            }
         }

         System.out.println("-----------------------------");
         System.out.println("Total acumulado: $" + var2);
         System.out.println("Producto de mayor valor: " + var4);
         var7.close();
      } catch (FileNotFoundException var14) {
         System.out.println("Error: El archivo productos.txt no existe.");
      }

   }
}
