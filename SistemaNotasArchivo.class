import java.io.File;
import java.io.FileNotFoundException;
import java.util.Scanner;

public class SistemaNotasArchivo {
   public SistemaNotasArchivo() {
   }

   public static void main(String[] var0) {
      File var1 = new File("estudiante.txt");
      if (!var1.exists()) {
         System.out.println("Error: el archivo no existe.");
      } else {
         int var2 = 0;
         int var3 = 0;
         double var4 = (double)0.0F;

         try {
            Scanner var6 = new Scanner(var1);

            while(var6.hasNext()) {
               String var7 = var6.next();
               double var8 = var6.nextDouble();
               double var10 = var6.nextDouble();
               double var12 = var6.nextDouble();
               double var14 = (var8 + var10 + var12) / (double)3.0F;
               System.out.println("Nombre: " + var7);
               System.out.println("Promedio: " + var14);
               if (var14 >= (double)7.0F) {
                  System.out.println("Estado: Aprobado");
                  ++var3;
               } else {
                  System.out.println("Estado: Reprobado");
               }

               var4 += var14;
               ++var2;
               System.out.println("----------------------");
            }

            var6.close();
            if (var2 > 0) {
               System.out.println("Total estudiantes: " + var2);
               System.out.println("Total aprobados: " + var3);
               System.out.println("Promedio general: " + var4 / (double)var2);
            }
         } catch (FileNotFoundException var16) {
            System.out.println("Error al leer el archivo.");
         }

      }
   }
}
