#include <iostream>
#include <fstream>
#include <string>
using namespace std;
int main() {
ifstream archivo("estudiantes.txt");
string nombre;
double n1, n2, n3, promedio;
int total = 0, aprobados = 0;
double suma = 0;
if (!archivo.is_open()) {
cout << "Error: No se pudo abrir el archivo." << endl;
return 1;
}
while (archivo >> nombre >> n1 >> n2 >> n3) {
promedio = (n1 + n2 + n3) / 3.0;
if (promedio >= 7) aprobados++;
suma += promedio;
total++;
}
if (total > 0) {
cout << "Total estudiantes: " << total << endl;
cout << "Total aprobados: " << aprobados << endl;
cout << "Promedio general: " << suma / total << endl;
} else {
cout << "El archivo estaba vacio o no tenia el formato correcto." << endl;
}
archivo.close();
return 0;
}
